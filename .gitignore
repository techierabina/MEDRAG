# Your actual API keys — this is the most important one
# never let this file touch GitHub
.env

# ChromaDB creates this folder when you run ingest.py
# no need to push it — everyone builds their own locally
chroma_db/

# Python creates these automatically, they are not part of our code
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtual environment — everyone creates their own locally
venv/
env/
.venv/

# Mac creates this file in every folder, we don't need it on GitHub
.DS_Store

# VS Code settings — personal to your machine
.vscode/